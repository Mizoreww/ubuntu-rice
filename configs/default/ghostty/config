# ubuntu-rice default Ghostty configuration
# Theme: TokyoNight Moon
# Docs: https://ghostty.org/docs/config/reference
# Show effective config: ghostty +show-config --default=false

# ===== Font =====
font-family = MesloLGS NF
font-size = 14

# ===== Theme (TokyoNight Moon is a built-in ghostty theme) =====
# List available themes: ghostty +list-themes
theme = TokyoNight Moon

# ===== Background opacity =====
# GNOME compositor does not honor background blur; KDE/macOS users may
# uncomment background-blur-radius below.
background-opacity = 0.88
# background-blur-radius = 20

# ===== Window =====
window-width = 140
window-height = 40
window-save-state = always
window-padding-x = 16
window-padding-y = 12
window-padding-balance = true
confirm-close-surface = false
window-decoration = true

# ===== Cursor =====
cursor-style = bar
cursor-style-blink = true

# ===== Scrolling / Mouse =====
scrollback-limit = 10000
mouse-hide-while-typing = true
copy-on-select = false

# ===== Bell =====
# ghostty 1.3.x does not expose audio/visual bell configuration

# ===== Copy / paste =====
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# ===== Font size hotkeys =====
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+zero=reset_font_size

# ===== New tab / window =====
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+n=new_window
